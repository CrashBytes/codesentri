{
  "name": "codesentri",
  "version": "0.1.0",
  "description": "AI-powered code review bot for GitHub",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "tunnel": "smee -u $SMEE_URL -t http://localhost:3001/api/webhook"
  },
  "keywords": [
    "github",
    "code-review",
    "ai",
    "claude"
  ],
  "author": "CrashBytes",
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/webhooks": "^13.4.2",
    "@octokit/webhooks-types": "^7.6.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "octokit": "^4.1.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "smee-client": "^2.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
